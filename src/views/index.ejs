<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="../css/index.css">
    <script src="../js/index.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400..900&display=swap" rel="stylesheet">
    <title>Document</title>
</head>
<body>
    <header>
        <div id="Header">
            <img src="../images/destiny.svg">
            <a href="/"><p>HOME</p></a>
            <div class="dropdown">
            <img class="class" src="../images/Classless.svg">
            <div class="dropdown-content">
                <a href="/login">LOGIN</a>
                <a href="/registro">REGISTER</a>
            </div>
        </div>
        </div>
        <div id="Selection">
            <p>Weapons</p>
            <p>Armor</p>
        </div>
    </header>
    <div id="Search">
        <img src="../images/search.png">
        <input type="text" placeholder="Search">
        <img src="../images/menu-button.svg" onclick="showFilters('Filters')">
    </div>
    <div id="Filters">
        <div>
            <img src="../images/empty-engram.svg">
            <button>Rare</button>
            <button>Legendary</button>
            <button>Exotic</button>
        </div>
        <div>
            <img src="../images/ammo-primary.svg">
            <button>Kinetic</button>
            <button>Energy</button>
            <button>Power</button>
        </div>
        <p>Type:</p>
        <select>
            <option>Auto Rifle</option>
        </select>
        <p>Type:</p>
        <select>
            <option>Kinetic</option>
        </select>
    </div>
    <p>YOUR ARMAMENT</p>
    <div id="Armament">
        <div class="weapon">
            <img src="images/arma1/Reckless Oracle.jpg" class="weapon-image">
            <img src="images/arma1/Smallbore.png" class="perk">
            <img src="images/arma1/Light Mag.png" class="perk">
            <img src="images/arma1/Outlaw.png" class="perk">
            <img src="images/arma1/Demolitionist.png" class="perk">
            <img src="images/arma1/Handling.jpg" class="perk">
        </div>
        <div class="weapon">
            <img src="images/arma2/Ikelos_SMG_V1.0.3.jpg" class="weapon-image">
            <img src="images/arma2/Corkscrew Rifling.png" class="perk">
            <img src="images/arma2/Seraph Rounds.png" class="perk">
            <img src="images/arma2/Perpetual Motion.png" class="perk">
            <img src="images/arma2/Voltshot.png" class="perk">
            <img src="images/arma2/Reload Speed.jpg" class="perk">
        </div>
    </div>
    <div id="Raids">
        <% Object.keys(raids).forEach(function(obtention) { %>
        <% const raidName = obtention.replace(/"/g, '').replace(' Raid', ''); %>
        <div class="raid">
            <img src="images/raids/<%= raidName %>.png">
            <p><%= raidName.toUpperCase() %></p>
            <div>
                <% raids[obtention].forEach(function(weapon) { %>
                <div class="raid-weapon">
                    <img src="/weapon-image/<%= weapon.id %>">
                    <br>
                    <img src="images/<%= damageTypeImages[weapon.damage_type] %>">
                    <img src="images/<%= ammoTypeImages[weapon.ammunition] %>">
                </div>
                <% }); %>
            </div>
        </div>
        <% }); %>
    </div>
</body>
</html>
